<div id="sr-cart-block" class="sr-block-container" {{ block.shopify_attributes }}>
  <script>
    window.SmartRecMeta = window.SmartRecMeta || {};
    window.SmartRecMeta.shopDomain = {{ shop.permanent_domain | json }};
    window.SmartRecMeta.appProxy = {{ shop.permanent_domain | prepend: "https://" | append: "/apps/smartrec" | json }};
    window.SmartRecMeta.pageType = {{ request.page_type | json }};
    window.SmartRecMeta.cartToken = {{ cart.token | default: "" | json }};
    window.SmartRecMeta.cartItemCount = {{ cart.item_count | default: 0 }};
    window.SmartRecMeta.customerId = {{ customer.id | default: "null" }};
    window.SmartRecMeta.templateName = {{ template.name | default: "" | json }};
    window.SmartRecMeta.enableTracking = true;
    window.SmartRecMeta.enableWidgets = true;
    window.SmartRecMeta.blockAnchor = "sr-cart-block";
  </script>

  {%- comment -%} Visible placeholder — replaced by JS when intent triggers {%- endcomment -%}
  <div class="sr-trust-placeholder" id="sr-cart-placeholder">
    <style>
      .sr-trust-placeholder {
        font-family: var(--font-body-family, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif);
        color: var(--color-foreground, inherit);
        background: var(--color-background, #fff);
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: var(--buttons-radius, 4px);
        padding: 12px 16px;
        margin: 12px 0;
        line-height: 1.5;
        box-sizing: border-box;
      }
      .sr-trust-placeholder * { box-sizing: border-box; }
      .sr-tp-item { padding: 8px 0; }
      .sr-tp-item + .sr-tp-item { border-top: 1px solid rgba(0,0,0,0.06); }
      .sr-tp-name {
        font-size: 13px;
        font-weight: 600;
        margin: 0 0 4px;
      }
      .sr-tp-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 6px;
        font-size: 13px;
      }
      .sr-tp-stars {
        color: #f59e0b;
        letter-spacing: 1px;
      }
      .sr-tp-reviews { color: #6b7280; }
      .sr-tp-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        font-size: 12px;
        font-weight: 500;
        background: rgba(16,185,129,0.1);
        color: #059669;
        border-radius: 99px;
      }
      @media (max-width: 749px) {
        .sr-tp-name { font-size: 12px; }
        .sr-tp-meta { font-size: 12px; }
      }
    </style>

    {%- if cart.item_count > 0 -%}
      {%- for item in cart.items limit: 3 -%}
        <div class="sr-tp-item">
          <p class="sr-tp-name">{{ item.product.title }}</p>
          <div class="sr-tp-meta">
            <span class="sr-tp-stars">★★★★☆</span>
            <span class="sr-tp-reviews">Đánh giá từ khách hàng</span>
            <span style="color:#d1d5db;">·</span>
            <span class="sr-tp-badge">↩ Đổi trả miễn phí 30 ngày</span>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="sr-tp-item">
        <p class="sr-tp-name">Sản phẩm trong giỏ hàng</p>
        <div class="sr-tp-meta">
          <span class="sr-tp-stars">★★★★☆</span>
          <span class="sr-tp-reviews">Đánh giá từ khách hàng</span>
          <span style="color:#d1d5db;">·</span>
          <span class="sr-tp-badge">↩ Đổi trả miễn phí 30 ngày</span>
        </div>
      </div>
      <p style="font-size:12px;color:#6b7280;margin:8px 0 0;">
        Trust nudge sẽ hiện rating thực và chính sách đổi trả khi khách ở cart page.
      </p>
    {%- endif -%}
  </div>

  {{ 'smartrec-signal-collector.js' | asset_url | script_tag }}
  {{ 'smartrec-widget-renderer.js' | asset_url | script_tag }}
</div>

{% schema %}
{
  "name": "SmartRec — Cart Trust",
  "target": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_trust_nudge",
      "label": "Enable Trust Nudge",
      "default": true,
      "info": "Hiện rating và chính sách đổi trả khi khách do dự ở cart"
    }
  ]
}
{% endschema %}
