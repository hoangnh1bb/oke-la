// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Pricing System Models
model UsageLog {
  id         Int      @id @default(autoincrement())
  shopId     String
  widgetType String
  productId  String?
  eventType  String
  srSource   Boolean  @default(false)
  timestamp  DateTime @default(now())

  @@index([shopId, timestamp])
}

model Subscription {
  id                 Int       @id @default(autoincrement())
  shopId             String    @unique
  plan               String    @default("free")
  status             String    @default("active")
  trialEndsAt        DateTime?
  billingCycleAnchor DateTime?
  shopifyChargeId    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model AddonSubscription {
  id              Int      @id @default(autoincrement())
  shopId          String
  addonType       String
  status          String   @default("active")
  shopifyChargeId String?
  createdAt       DateTime @default(now())

  @@index([shopId, addonType])
}

model ShopConfig {
  shopId        String   @id
  primaryColor  String   @default("#4A90E2")
  headlineText  String   @default("Bạn có thể thích")
  widgetColors  String?  // JSON
  widgetTexts   String?  // JSON
  buttonStyle   String   @default("solid")
  updatedAt     DateTime @updatedAt
}

model OrderAttribution {
  id         Int      @id @default(autoincrement())
  shopId     String
  orderId    String   @unique
  productIds String   // JSON array
  orderTotal Float
  createdAt  DateTime @default(now())

  @@index([shopId, createdAt])
}

// SmartRec — Merchant settings per store (pluggable thresholds)
model SmartRecSettings {
  id                    String   @id @default(cuid())
  shop                  String   @unique
  enabled               Boolean  @default(true)
  alternativeNudge      Boolean  @default(true)
  comparisonBar         Boolean  @default(true)
  tagNavigator          Boolean  @default(true)
  thresholdBrowsing     Int      @default(30)
  thresholdConsidering  Int      @default(55)
  thresholdHighIntent   Int      @default(75)
  thresholdStrongIntent Int      @default(89)
  thresholdReadyToBuy   Int      @default(90)
  ucHesitationMin       Int      @default(56)
  ucHesitationMax       Int      @default(89)
  ucLostBackNavMin      Int      @default(3)
  maxAlternatives       Int      @default(2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SubstitutionCache {
  id              Int      @id @default(autoincrement())
  shop            String
  sourceProductId String
  targetProductId String
  frequency       Int      @default(1)
  updatedAt       DateTime @updatedAt

  @@unique([shop, sourceProductId, targetProductId])
  @@index([shop, sourceProductId])
}

model SmartRecEvent {
  id        String   @id @default(cuid())
  shop      String
  eventType String
  widgetType String?
  productId  String?
  sessionId  String?
  intentScore Int?
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([shop, createdAt])
  @@index([shop, widgetType])
}
