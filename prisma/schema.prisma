// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Pricing System Models
model UsageLog {
  id         Int      @id @default(autoincrement())
  shopId     String
  widgetType String
  productId  String?
  eventType  String
  srSource   Boolean  @default(false)
  timestamp  DateTime @default(now())

  @@index([shopId, timestamp])
}

model Subscription {
  id                 Int       @id @default(autoincrement())
  shopId             String    @unique
  plan               String    @default("free")
  status             String    @default("active")
  trialEndsAt        DateTime?
  billingCycleAnchor DateTime?
  shopifyChargeId    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model AddonSubscription {
  id              Int      @id @default(autoincrement())
  shopId          String
  addonType       String
  status          String   @default("active")
  shopifyChargeId String?
  createdAt       DateTime @default(now())

  @@index([shopId, addonType])
}

model ShopConfig {
  shopId        String   @id
  primaryColor  String   @default("#4A90E2")
  headlineText  String   @default("Bạn có thể thích")
  widgetColors  String?  // JSON
  widgetTexts   String?  // JSON
  buttonStyle   String   @default("solid")
  updatedAt     DateTime @updatedAt
}

model OrderAttribution {
  id         Int      @id @default(autoincrement())
  shopId     String
  orderId    String   @unique
  productIds String   // JSON array
  orderTotal Float
  createdAt  DateTime @default(now())

  @@index([shopId, createdAt])
}

// SmartRec — Merchant settings per store (pluggable thresholds)
model SmartRecSettings {
  id                    Int      @id @default(autoincrement())
  shop                  String   @unique
  enabled               Boolean  @default(true)
  // UC-01: Hesitating Shopper thresholds
  ucHesitationEnabled   Boolean  @default(true)
  ucHesitationMin       Int      @default(56)
  ucHesitationMax       Int      @default(89)
  // UC-02: Comparison Shopper
  ucCompareEnabled      Boolean  @default(true)
  // UC-03: Lost Shopper
  ucLostEnabled         Boolean  @default(true)
  ucLostBackNavMin      Int      @default(3)
  // UC-04: Cart Doubt
  ucCartEnabled         Boolean  @default(true)
  ucCartHesitationSec   Int      @default(60)
  // General
  maxAlternatives       Int      @default(2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// SmartRec — Substitution patterns from order history (view A → buy B)
model SubstitutionCache {
  id            Int      @id @default(autoincrement())
  shop          String
  sourceProductId String  // Product that was viewed
  targetProductId String  // Product that was actually purchased
  frequency     Int      @default(1) // How many times this pattern occurred
  updatedAt     DateTime @updatedAt

  @@unique([shop, sourceProductId, targetProductId])
  @@index([shop, sourceProductId])
}

// SmartRec — Analytics events (impressions, clicks, dismissals)
model AnalyticsEvent {
  id          Int      @id @default(autoincrement())
  shop        String
  sessionId   String
  eventType   String   // "impression" | "click" | "dismiss"
  widgetType  String   // "alternative_nudge" | "comparison_bar" | "tag_navigator" | "trust_nudge"
  productId   String?
  intentScore Int?
  metadata    String?  // JSON string for extra data
  createdAt   DateTime @default(now())

  @@index([shop, createdAt])
  @@index([widgetType, eventType])
}
